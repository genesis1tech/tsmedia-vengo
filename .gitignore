# macOS
.DS_Store

# Git worktrees
.worktrees/

# Local Factory/Droid state
.factory/
.missions/

# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info
.coverage

# Virtual environments
.venv

# Virtual environments
venv/
barcode_env/

# Installation files
*.zip

# Media files
*.mp4
*.avi
*.mov

# AI/ML model files
.qwen/

# Environment files
.env
.env.*

# Backup and temporary files
*.backup
*.backup*
*.debug
*.ota-temp
*.pre-ota
*~
.*.swp

# OTA staging directories
/tmp/ota_staging/
/tmp/ota_backup/
/tmp/media_staging/

# Image cache
image_cache/

# Certificates and private keys - SECURITY CRITICAL
assets/certs/*.pem
assets/certs/*.key
assets/certs/*.crt
assets/certs/secrets.json
!assets/certs/.gitkeep
assets/certs/device-config.json

# Fleet deployment - real device lists (contain IPs/hostnames)
devices.txt
devices*.txt
!devices.txt.example

# First-boot marker
.first-boot-complete

# Deployment logs
logs/deploy-*.log
logs/first-boot-*.log

# Provisioning reports (contain device-specific data)
assets/certs/provisioning-report.json

# Documentation (ignore generated docs, keep essential ones)
*.md
!README.md
!CLAUDE.md
!CONTRACT.md
!AGENTS.md
!docs/enterprise-wifi-fix.md
!docs/NFC_QR_REPLICATION_GUIDE.md
!docs/V2_BRAND_PLAYLISTS.md
!docs/superpowers/**/*.md
.gstack/
